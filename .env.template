NODE_ENV=production

BASE_URL=

TELEGRAM_BOT_TOKEN=

LOG_GROUP_ID=
LOG_TOPIC_ID=

# Database Configuration
# Docker local dev: postgresql://bitcoindeepa_dca:bitcoindeepa_dca@localhost:5432/bitcoindeepa_dca
DATABASE_URL=postgresql://bitcoindeepa_dca:bitcoindeepa_dca@localhost:5432/bitcoindeepa_dca
# OR individual values:
PG_HOST=localhost
PG_PORT=5432
PG_DB=bitcoindeepa_dca
PG_USER=bitcoindeepa_dca
PG_PW=bitcoindeepa_dca

JWT_SECRET=

# Authentication
ENABLE_AUTH=true
MOCK_TG_ID=

# PayHere Configuration
PAYHERE_APP_ID=
PAYHERE_APP_SECRET=
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_RETURN_URL=
PAYHERE_CANCEL_URL=
PAYHERE_NOTIFY_URL=
PAYHERE_ENV=sandbox # live or sandbox

# Redis Configuration
# Docker local dev: redis://default:redis_password@localhost:6379/0
REDIS_URL=redis://default:redis_password@localhost:6379/0
REDIS_TTL_DEFAULT=300

# Bitcoin DCA Configuration
COINGECKO_API_KEY=
ENABLE_BITCOIN_TRACKING=true
BITCOIN_PRICE_CACHE_TTL=20

# Fee Configuration (in basis points - 1 basis point = 0.01%)
# Example: 100 = 1%, 250 = 2.5%, 500 = 5%
PAYHERE_FEE_BASIS_POINTS=100    # PayHere transaction fee
CEYPAY_FEE_BASIS_POINTS=100     # CeyPay transaction fee (to be implemented)
BITCOINDEEPA_FEE_BASIS_POINTS=100  # BitcoinDeepa platform fee

# BitcoinDeepa Fund Transfer API Configuration
BITCOINDEEPA_API_URL=
BITCOINDEEPA_HMAC_SECRET=
BITCOINDEEPA_TIMEOUT=10000

# Deployment
PORT=3000
CORS_ORIGIN=*

DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=
DIDIT_WORKFLOW_ID=
DIDIT_REDIRECT_URL=
DIDIT_BASE_URL=https://api.didit.me

# Migrations
ANALYTICS_READONLY_PASSWORD=
